<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+. Receipt data, tokens, and images are excluded
    from both cloud backup and device-to-device transfer because they contain sensitive
    financial information (card last-4, raw OCR text, YNAB auth credentials).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="receipt_scanner.db" />
        <exclude domain="file" path="receipts" />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
        <exclude domain="sharedpref" path="user_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="receipt_scanner.db" />
        <exclude domain="file" path="receipts" />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
        <exclude domain="sharedpref" path="user_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
